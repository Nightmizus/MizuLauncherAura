<Window x:Class="MizuLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MizuLauncher Aura" Height="450" Width="750"
        MinHeight="450" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        Foreground="White"
        FontFamily="Microsoft YaHei UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="-1" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <CornerRadius x:Key="MainCornerRadius">12</CornerRadius>
        <SolidColorBrush x:Key="CardBackground" Color="White" Opacity="0.03"/>
        <SolidColorBrush x:Key="CardBorder" Color="Transparent"/>
        <SolidColorBrush x:Key="VisibleBorderBrush" Color="White" Opacity="0.1"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="White" Opacity="0.1"/>
        <SolidColorBrush x:Key="SystemAccentBrush" Color="#FF0078D7"/>

        <!-- 噪点纹理笔刷 (Noise Texture) -->
        <DrawingBrush x:Key="NoiseBrush" 
                      Viewport="0,0,128,128" ViewportUnits="Absolute" 
                      TileMode="Tile" Stretch="None" Opacity="0.05">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!-- 噪点底层透明背板 -->
                    <GeometryDrawing Geometry="M0,0 H128 V128 H0Z">
                        <GeometryDrawing.Brush>
                            <SolidColorBrush Color="Transparent"/>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                    <!-- 噪点颗粒：通过大量的极小点模拟细微颗粒感 -->
                    <GeometryDrawing>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="10,10" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="30,45" RadiusX="0.6" RadiusY="0.6"/>
                                <EllipseGeometry Center="60,20" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="90,80" RadiusX="0.7" RadiusY="0.7"/>
                                <EllipseGeometry Center="110,40" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="20,90" RadiusX="0.6" RadiusY="0.6"/>
                                <EllipseGeometry Center="50,110" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="85,15" RadiusX="0.6" RadiusY="0.6"/>
                                <EllipseGeometry Center="120,70" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="40,30" RadiusX="0.7" RadiusY="0.7"/>
                                <EllipseGeometry Center="75,95" RadiusX="0.5" RadiusY="0.5"/>
                                <EllipseGeometry Center="5,115" RadiusX="0.6" RadiusY="0.6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                        <GeometryDrawing.Brush>
                            <SolidColorBrush Color="White"/>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 通用输入控件样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="SelectionBrush" Value="#40FFFFFF"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="SelectionBrush" Value="#40FFFFFF"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderThickness="0" 
                                          Grid.Column="2" 
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="templateRoot" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Data="M 0 0 L 4 4 L 8 0" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="templateRoot" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentPresenter" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left" 
                                              IsHitTestVisible="false"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Grid.ColumnSpan="2" IsOpen="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Margin="1" Placement="Bottom" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="#F01E1E1E" CornerRadius="10" Margin="0,4,0,0" BorderBrush="#30FFFFFF" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer x:Name="DropDownScrollViewer" MaxHeight="300">
                                        <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 全局右键菜单样式，修复黑底黑字问题 -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#F02A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="8,0" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#60FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 全局提示框样式 -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#F02A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="BaseButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding Tag}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Rectangle x:Name="ThumbBorder" Fill="#40FFFFFF" RadiusX="1.5" RadiusY="1.5" Width="3" HorizontalAlignment="Right"/>
                                                <ControlTemplate.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="Width" To="6" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="RadiusX" To="3" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="RadiusY" To="3" Duration="0:0:0.1"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="Width" To="3" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="RadiusX" To="1.5" Duration="0:0:0.1"/>
                                                                <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="RadiusY" To="1.5" Duration="0:0:0.1"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid x:Name="ScrollViewerRoot" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" CanHorizontallyScroll="False" CanVerticallyScroll="False" ContentTemplate="{TemplateBinding ContentTemplate}" Content="{TemplateBinding Content}" Grid.Column="0" Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar" Cursor="Arrow" Grid.Column="1" Maximum="{TemplateBinding ScrollableHeight}" Minimum="0" Orientation="Vertical" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Value="{TemplateBinding VerticalOffset}" ViewportSize="{TemplateBinding ViewportHeight}" Style="{StaticResource ModernScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#A0FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="Indicator" Height="3" Width="12" Background="White" VerticalAlignment="Bottom" Margin="0,0,0,2" CornerRadius="1.5" Visibility="Hidden"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                <Setter Property="Foreground" Value="#60FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style x:Key="PlayerListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Margin="2">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="删除玩家" Click="DeletePlayer_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="20" Height="20" Background="#30FFFFFF" CornerRadius="3">
                                     <Image Source="{Binding Avatar}" 
                                            Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                 </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="13"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerCardToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="{StaticResource MainCornerRadius}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VersionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="{StaticResource MainCornerRadius}" IsHitTestVisible="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainRoot" Background="Transparent">

        <!-- 默认亚克力纯黑蒙层 -->
        <Border x:Name="BgTint" Background="#60000000" IsHitTestVisible="False"/>

        <!-- 噪点蒙层 (Noise Overlay) -->
        <Rectangle x:Name="NoiseLayer" Fill="{StaticResource NoiseBrush}" IsHitTestVisible="False"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,12,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="MizuLauncher Aura" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                    <RadioButton x:Name="BtnHome" Content="首页" Style="{StaticResource NavButtonStyle}" IsChecked="True" Click="BtnHome_Click" GroupName="NavGroup"/>
                    <RadioButton x:Name="BtnDownload" Content="下载" Style="{StaticResource NavButtonStyle}" Margin="10,0,0,0" Click="BtnDownload_Click" GroupName="NavGroup"/>
                    <RadioButton x:Name="BtnAIChat" Content="AI 对话" Style="{StaticResource NavButtonStyle}" Margin="10,0,0,0" Click="BtnAIChat_Click" GroupName="NavGroup"/>
                    <RadioButton x:Name="BtnMore" Content="更多" Style="{StaticResource NavButtonStyle}" Margin="10,0,0,0" Click="BtnMore_Click" GroupName="NavGroup"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,0,0" VerticalAlignment="Center">
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BaseButtonStyle}" Tag="8" Foreground="White" Width="40" Height="40" FontSize="10" Click="BtnMinimize_Click"/>
                    <Button Content="" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BaseButtonStyle}" Tag="8" Foreground="White" Width="40" Height="40" FontSize="10" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="12,12,12,0">
                <!-- 首页内容 -->
                <Grid x:Name="HomeContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 原版本列表已移除 -->
                    <Border Grid.Column="0" Background="Transparent" Margin="0,0,6,0"/>

                    <Border Grid.Column="1" Margin="6,0,0,0" Background="Transparent">
                        <Grid>
                            <!-- 版本设置面板 -->
                            <Grid x:Name="VersionSettingsPanel" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                                    <TextBlock Text="版本设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                                    
                                    <Button Content="导出键位配置" Style="{StaticResource BaseButtonStyle}" Height="40" Margin="0,0,0,10" Click="BtnExportConfig_Click" Tag="12"/>
                                    
                                    <Grid Margin="0,10,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ComboSavedConfigs" Height="40" Margin="0,0,10,0"/>
                                        <Button Grid.Column="1" Content="导入" Style="{StaticResource BaseButtonStyle}" Width="80" Height="40" Click="BtnImportConfig_Click" Tag="12"/>
                                    </Grid>
                                    
                                    <Button Content="返回" Style="{StaticResource BaseButtonStyle}" Height="35" Width="100" Margin="0,20,0,0" Click="BtnVersionSettings_Click" Tag="8"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 下载页面内容 -->
                <Grid x:Name="DownloadContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="10,0,10,15">
                        <RadioButton x:Name="TabGameCore" Content="游戏核心" Style="{StaticResource NavButtonStyle}" IsChecked="True" GroupName="DownloadTab" Click="DownloadTab_Click"/>
                        <RadioButton x:Name="TabModSearch" Content="模组搜索" Style="{StaticResource NavButtonStyle}" Margin="10,0,0,0" GroupName="DownloadTab" Click="DownloadTab_Click"/>
                        <RadioButton x:Name="TabDownloadTasks" Content="下载任务" Style="{StaticResource NavButtonStyle}" Margin="10,0,0,0" GroupName="DownloadTab" Click="DownloadTab_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <!-- 游戏核心下载 -->
                        <Grid x:Name="GameCorePanel" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Background="{StaticResource CardBackground}" CornerRadius="12" Margin="0,0,10,0">
                                <DockPanel>
                                    <TextBlock Text="核心版本" DockPanel.Dock="Top" Margin="15,15,15,10" FontWeight="Bold" FontSize="16"/>
                                    <Button x:Name="BtnRefreshVanilla" Content="刷新版本列表" DockPanel.Dock="Bottom" Margin="10" Style="{StaticResource BaseButtonStyle}" Height="35" Click="BtnRefreshVanilla_Click" Tag="12"/>
                                    <ListBox x:Name="ListVanillaVersions" Background="Transparent" BorderThickness="0" Margin="5" ItemContainerStyle="{StaticResource VersionListItemStyle}" SelectionChanged="ListVanillaVersions_SelectionChanged"/>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="12">
                                <Grid x:Name="VersionInstallPanel" Visibility="Collapsed">
                                    <StackPanel Margin="20">
                                        <TextBlock x:Name="TxtSelectedVersion" Text="选择一个版本" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                                        
                                        <TextBlock Text="选择加载器" FontSize="14" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <RadioButton x:Name="RadioVanilla" Content="Vanilla" IsChecked="True" Foreground="White" Margin="0,0,15,0" Checked="LoaderRadio_Checked"/>
                                            <RadioButton x:Name="RadioForge" Content="Forge" Foreground="White" Margin="0,0,15,0" Checked="LoaderRadio_Checked"/>
                                            <RadioButton x:Name="RadioFabric" Content="Fabric" Foreground="White" Margin="0,0,15,0" Checked="LoaderRadio_Checked"/>
                                            <RadioButton x:Name="RadioQuilt" Content="Quilt" Foreground="White" Checked="LoaderRadio_Checked"/>
                                        </StackPanel>

                                        <TextBlock x:Name="TxtLoaderVersionLabel" Text="加载器版本" FontSize="14" Margin="0,0,0,10" Visibility="Collapsed"/>
                                        <ComboBox x:Name="ComboLoaderVersions" Height="35" Margin="0,0,0,20" Visibility="Collapsed"/>

                                        <Button x:Name="BtnInstallVersion" Content="开始安装" Style="{StaticResource PrimaryButtonStyle}" Width="150" HorizontalAlignment="Left" Click="BtnInstallVersion_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 模组搜索 -->
                        <Grid x:Name="ModSearchPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="ModSearchHeader" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtModSearchQuery" Height="38" Padding="15,0" Tag="搜索模组..."/>
                                <ComboBox Grid.Column="1" x:Name="ComboModSource" Width="120" Height="38" Margin="10,0,0,0">
                                    <ComboBoxItem Content="Modrinth" IsSelected="True"/>
                                    <ComboBoxItem Content="CurseForge"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="搜索" Width="100" Height="38" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="BtnModSearch_Click"/>
                            </Grid>

                            <!-- 搜索结果列表 -->
                            <ListBox x:Name="ListModResults" Grid.Row="1" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource VersionListItemStyle}" Visibility="Visible">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" Background="#30FFFFFF" CornerRadius="8">
                                                <Image Source="{Binding IconUrl}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="{Binding Author}" FontSize="12" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="查看版本" VerticalAlignment="Center" Padding="15,5" Style="{StaticResource BaseButtonStyle}" Click="BtnShowModVersions_Click" Tag="8"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- 模组版本列表 -->
                            <Grid x:Name="ModVersionsPanel" Grid.Row="1" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Button Content="返回搜索结果" Style="{StaticResource BaseButtonStyle}" HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,10" Click="BtnBackToModSearch_Click" Tag="8"/>
                                
                                <ListBox x:Name="ListModVersions" Grid.Row="1" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource VersionListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding VersionNumber}" FontWeight="Bold" FontSize="14"/>
                                                        <Border Background="#30FFFFFF" CornerRadius="4" Margin="10,0,0,0" Padding="5,2">
                                                            <TextBlock Text="{Binding DisplayType}" FontSize="10" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DisplayGameVersions}" FontSize="12" Foreground="#80FFFFFF" Margin="0,5,0,0"/>
                                                    <TextBlock Text="{Binding DisplayLoaders}" FontSize="12" Foreground="#50A2FF" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="下载" VerticalAlignment="Center" Padding="15,5" Style="{StaticResource BaseButtonStyle}" Click="BtnDownloadModVersion_Click" Tag="8"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>

                        <!-- 下载任务 -->
                        <Grid x:Name="DownloadTasksPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="清空已完成" Style="{StaticResource BaseButtonStyle}" Padding="15,5" Click="BtnClearCompleted_Click" Tag="8"/>
                                <Button Content="打开模组文件夹" Style="{StaticResource BaseButtonStyle}" Margin="10,0,0,0" Padding="15,5" Click="BtnOpenModsFolder_Click" Tag="8"/>
                            </StackPanel>

                            <ListBox Grid.Row="1" x:Name="ListDownloadTasks" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#10FFFFFF" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,0,5"/>
                                                    <ProgressBar Value="{Binding Progress}" Height="4" Background="#20FFFFFF" Foreground="#FF00A2FF" BorderThickness="0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#80FFFFFF" FontSize="12"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 更多页面内容 -->
                <Grid x:Name="MoreContent" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="设置" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                            
                            <!-- 个性化 -->
                            <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="个性化" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="背景效果" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <RadioButton x:Name="RadioMica" Content="云母 (Mica)" Click="RadioBg_Click" Margin="0,0,20,0" Foreground="White"/>
                                        <RadioButton x:Name="RadioAcrylic" Content="亚克力 (Acrylic)" Click="RadioBg_Click" Margin="0,0,20,0" Foreground="White"/>
                                        <RadioButton x:Name="RadioButtonSolid" Content="纯色 (Solid)" Click="RadioBg_Click" Foreground="White"/>
                                    </StackPanel>

                                    <StackPanel x:Name="SolidColorSettings" Visibility="Collapsed">
                                        <TextBlock Text="背景色选择" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button Content="黑色" Click="ColorBtn_Click" Tag="#FF000000" Style="{StaticResource BaseButtonStyle}" Margin="0,0,5,0" Width="60" Height="30"/>
                                            <Button Content="深灰" Click="ColorBtn_Click" Tag="#FF1E1E1E" Style="{StaticResource BaseButtonStyle}" Margin="0,0,5,0" Width="60" Height="30"/>
                                            <Button Content="深蓝" Click="ColorBtn_Click" Tag="#FF001220" Style="{StaticResource BaseButtonStyle}" Margin="0,0,5,0" Width="60" Height="30"/>
                                            <Button Content="深紫" Click="ColorBtn_Click" Tag="#FF120020" Style="{StaticResource BaseButtonStyle}" Margin="0,0,5,0" Width="60" Height="30"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <TextBox x:Name="TxtCustomColor" Width="100" Height="35" VerticalContentAlignment="Center" Margin="0,0,10,0" Text="#FF1E1E1E"/>
                                            <Button Content="应用" Click="ApplyCustomColor_Click" Style="{StaticResource BaseButtonStyle}" Width="80" Height="35"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="默认 AI 模型" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="ComboAiProvider" Height="38" SelectionChanged="ComboAiProvider_SelectionChanged">
                                        <ComboBoxItem Content="DeepSeek" IsSelected="True"/>
                                        <ComboBoxItem Content="GLM (ZhipuAI)"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- DeepSeek AI 设置 -->
                            <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="DeepSeek AI 设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="API Key" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <PasswordBox x:Name="TxtDeepSeekApiKey" Height="38" Margin="0,0,0,20" PasswordChanged="TxtDeepSeekApiKey_PasswordChanged"/>
                                    
                                    <TextBlock Text="模型选择" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="ComboDeepSeekModel" Height="38" SelectionChanged="ComboDeepSeekModel_SelectionChanged">
                                        <ComboBoxItem Content="deepseek-chat" IsSelected="True"/>
                                        <ComboBoxItem Content="deepseek-reasoner"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- GLM AI 设置 -->
                            <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="GLM AI 设置 (ZhipuAI)" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                                    
                                    <TextBlock Text="API Key (将同步至桌面)" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <PasswordBox x:Name="TxtGlmApiKey" Height="38" Margin="0,0,0,20" PasswordChanged="TxtGlmApiKey_PasswordChanged"/>
                                    
                                    <TextBlock Text="模型选择" FontSize="13" Foreground="#B0FFFFFF" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="ComboGlmModel" Height="38" SelectionChanged="ComboGlmModel_SelectionChanged">
                                         <ComboBoxItem Content="glm-4-flash"/>
                                         <ComboBoxItem Content="glm-4.7-flash" IsSelected="True"/>
                                         <ComboBoxItem Content="glm-4-plus"/>
                                     </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- AI 对话内容 -->
                <Grid x:Name="AIChatContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Margin="10" Background="#15FFFFFF" CornerRadius="12">
                        <TextBox x:Name="TxtAIResponse" Padding="15" FontSize="15" Foreground="White" 
                                 Background="Transparent" BorderThickness="0"
                                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" Text="你好！我是你的 AI 助手，有什么可以帮你的吗？"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtAIChatInput" Height="42" Margin="0" Padding="15,0" Tag="输入消息..."/>
                        <Button Grid.Column="1" Content="发送" Click="BtnAIChatSend_Click" 
                                Style="{StaticResource PrimaryButtonStyle}" Width="100" Height="42" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 第一行：超大版本名称 -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <ToggleButton x:Name="BtnVersionSelect" Style="{StaticResource PlayerCardToggleStyle}" 
                                  Height="Auto" HorizontalAlignment="Left"
                                  MouseEnter="BtnVersionSelect_MouseEnter"
                                  MouseLeave="BtnVersionSelect_MouseLeave">
                        <TextBlock x:Name="TxtCurrentVersion" Text="未选择版本" FontSize="48" FontWeight="Bold" 
                                   Foreground="White" TextTrimming="CharacterEllipsis" Margin="8,0"/>
                    </ToggleButton>
                </Grid>

                <!-- 第二行：玩家信息与功能按钮对齐 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,6,0">
                        <ToggleButton x:Name="BtnPlayerCard" Style="{StaticResource PlayerCardToggleStyle}" 
                                      VerticalAlignment="Center" Height="48"
                                      MouseEnter="BtnPlayerCard_MouseEnter"
                                      MouseLeave="BtnPlayerCard_MouseLeave">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="30" Height="30" Background="#30FFFFFF" CornerRadius="4">
                                    <Image x:Name="ImgPlayerAvatar" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock x:Name="TxtPlayerName" Text="添加玩家" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock x:Name="TxtPlayerType" Text="离线模式" FontSize="10" Foreground="#80FFFFFF"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Opacity="0.5">
                                    <Path Data="M 0 0 L 4 4 L 8 0" Stroke="White" StrokeThickness="1.5"/>
                                    <Path Data="M 0 4 L 4 0 L 8 4" Stroke="White" StrokeThickness="1.5" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </ToggleButton>
                    </Grid>

                    <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="{StaticResource MainCornerRadius}" 
                            Margin="6,0" VerticalAlignment="Center" Height="48" BorderBrush="{StaticResource VisibleBorderBrush}" BorderThickness="1"
                            x:Name="BorderProgress" ClipToBounds="True" Visibility="Collapsed">
                        <Grid>
                            <Rectangle x:Name="RectProgress" Fill="#40FFFFFF" HorizontalAlignment="Left" Width="0" RadiusX="12" RadiusY="12"/>
                            <TextBlock x:Name="TxtProgressStep" Text="等待中..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="5,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="Transparent" CornerRadius="{StaticResource MainCornerRadius}" 
                            Margin="6,0" VerticalAlignment="Center" Height="48" Width="48" BorderBrush="Transparent" BorderThickness="0">
                        <Button x:Name="BtnVersionSettings" Content="" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BaseButtonStyle}" Tag="{StaticResource MainCornerRadius}" Foreground="White" FontSize="20" Width="48" Height="48" Click="BtnVersionSettings_Click"/>
                    </Border>

                    <Button x:Name="BtnLaunch" Grid.Column="3" Content="启动游戏" Click="BtnLaunch_Click" VerticalAlignment="Center" Height="48" Width="140" Margin="6,0,0,0" FontWeight="Bold" FontSize="16" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource SystemAccentBrush}" CornerRadius="12">
                                    <ContentPresenter x:Name="Presenter" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="Black"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                                        <Setter TargetName="Presenter" Property="TextElement.Foreground" Value="#40000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- 版本选择 Overlay -->
        <Border x:Name="VersionListOverlay" 
                Width="240" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="20,0,0,152" Background="#FF1E1E1E" CornerRadius="12" 
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" 
                Visibility="Collapsed" Opacity="0"
                MouseEnter="PopupVersions_MouseEnter"
                MouseLeave="PopupVersions_MouseLeave">
            <Border.RenderTransform>
                <TranslateTransform x:Name="VersionOverlayTransform" Y="20"/>
            </Border.RenderTransform>
            <DockPanel Margin="5">
                <ListBox x:Name="ListVersions" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource VersionListItemStyle}"
                         SelectionChanged="ListVersions_SelectionChanged"/>
            </DockPanel>
        </Border>

        <!-- 账号选择 Overlay -->
        <Border x:Name="PlayerListOverlay" 
                Width="220" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="20,0,0,80" Background="#FF1E1E1E" CornerRadius="12" 
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" 
                Visibility="Collapsed" Opacity="0"
                MouseEnter="PopupPlayers_MouseEnter"
                MouseLeave="PopupPlayers_MouseLeave">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PlayerOverlayTransform" Y="20"/>
            </Border.RenderTransform>
            <StackPanel Margin="5">
                <Button Content="+" FontSize="18" FontWeight="Bold" Style="{StaticResource BaseButtonStyle}" Foreground="#80FFFFFF" Height="35" Click="BtnAddPlayer_Click"/>
                
                <TextBlock Text="正版账号" Foreground="#60FFFFFF" FontSize="10" Margin="10,5,0,2"/>
                <ListBox x:Name="ListOnlinePlayers" Background="Transparent" BorderThickness="0" MaxHeight="150"
                         ItemContainerStyle="{StaticResource PlayerListItemStyle}"
                         SelectionChanged="ListPlayers_SelectionChanged"/>

                <Border Background="#20FFFFFF" Height="1" Margin="10,5"/>

                <TextBlock Text="离线账号" Foreground="#60FFFFFF" FontSize="10" Margin="10,5,0,2"/>
                <ListBox x:Name="ListOfflinePlayers" Background="Transparent" BorderThickness="0" MaxHeight="250"
                         ItemContainerStyle="{StaticResource PlayerListItemStyle}"
                         SelectionChanged="ListPlayers_SelectionChanged"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>